<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameGuideHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background: #1a0a2e; color: #e0d8f0;">

    <div class="container py-3">
        <nav class="navbar navbar-expand-lg navbar-dark mb-3">
            <a class="navbar-brand" href="/" style="color: white; font-size: 1.3rem;">🎮 GameGuideHub</a>
        </nav>

        @RenderBody()

        <footer style="text-align: center; margin-top: 2rem; padding: 1rem; color: #777;">
            <p style="font-size: 0.7rem;">GameGuideHub — описания, оценки, онлайн, лор, обновления и гайды</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>